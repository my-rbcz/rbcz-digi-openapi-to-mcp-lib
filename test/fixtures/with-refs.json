{
    "openapi": "3.0.0",
    "info": { "title": "WithRefs", "version": "1.0.0" },
    "paths": {
        "/users": {
            "get": {
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": { "$ref": "#/components/schemas/User" }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "User": {
                "type": "object",
                "properties": {
                    "id": { "type": "string" },
                    "address": { "$ref": "#/components/schemas/Address" }
                }
            },
            "Address": {
                "type": "object",
                "properties": {
                    "city": { "type": "string" }
                }
            }
        }
    }
}
