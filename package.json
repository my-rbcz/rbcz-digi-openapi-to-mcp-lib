{
    "name": "rbcz-digi-openapi-to-mcp-lib",
    "version": "0.3.0",
    "description": "Turns OpenAPI specs into MCP tool definitions, schema filters, and response validators.",
    "license": "UNLICENSED",
    "private": true,
    "type": "module",
    "engines": {
        "node": ">=20.0.0"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsc",
        "tsc-check": "tsc --noEmit",
        "test": "vitest --run",
        "test:watch": "vitest --watch",
        "coverage": "vitest run --coverage",
        "eslint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
        "eslint-fix": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --fix"
    },
    "dependencies": {
        "@apidevtools/swagger-parser": "^12.1.0",
        "ajv": "^8.17.1",
        "ajv-formats": "^3.0.1",
        "js-yaml": "^4.1.0",
        "openapi-types": "^12.1.3"
    },
    "devDependencies": {
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^22.7.9",
        "@typescript-eslint/eslint-plugin": "^8.29.1",
        "@typescript-eslint/parser": "^8.29.1",
        "@vitest/coverage-v8": "^3.1.2",
        "eslint": "^9.24.0",
        "eslint-config-prettier": "^10.1.2",
        "eslint-plugin-prettier": "^5.2.6",
        "prettier": "^3.5.3",
        "typescript": "~5.6.3",
        "vitest": "^3.1.2"
    }
}